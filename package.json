{
  "name": "pisky",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:web": "pnpm --filter web dev",
    "dev:admin": "pnpm --filter admin dev",
    "db:up": "docker compose -f tooling/docker/postgres/compose.yml up -d",
    "db:down": "docker compose -f tooling/docker/postgres/compose.yml down",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck",
    "hooks:install": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.29.1",
    "vitest": "^4.1.4"
  }
}
