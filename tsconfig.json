{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "types": ["node"],
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@pisky/auth": ["./packages/auth/src"],
      "@pisky/config": ["./packages/config/src"],
      "@pisky/config/*": ["./packages/config/src/*"],
      "@pisky/db": ["./packages/db/src"],
      "@pisky/ui": ["./packages/ui/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
